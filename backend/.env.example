# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env

# Database
DB_HOST=localhost
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Server
PORT=5000

# JWT Secret (ganti dengan string acak yang panjang)
JWT_SECRET=ganti_dengan_secret_key_yang_kuat

# URL aplikasi (untuk link reset password di email)
APP_URL=https://yourdomain.com
